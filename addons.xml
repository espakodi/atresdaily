<?xml version="1.0" encoding="UTF-8"?>
<addons>
    <addon id="repository.atresdaily" name="AtresDaily Repository" version="1.0.0" provider-name="RubénSDFA1labernt">
        <extension point="xbmc.addon.repository" name="AtresDaily Repository">
            <dir>
                <info compressed="false">https://fullstackcurso.github.io/atresdaily/addons.xml</info>
                <checksum>https://fullstackcurso.github.io/atresdaily/addons.xml.md5</checksum>
                <datadir zip="true">https://fullstackcurso.github.io/atresdaily/</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="es">Repositorio de AtresDaily</summary>
            <description lang="es">Repositorio oficial para instalar y actualizar el addon AtresDaily.</description>
            <platform>all</platform>
            <assets>
                <icon>icon.png</icon>
                <fanart>fanart.png</fanart>
            </assets>
        </extension>
    </addon>
    <addon id="plugin.video.atresdaily" name="AtresDaily" version="1.0.3" provider-name="RubénSDFA1labernt">
        <requires>
            <import addon="xbmc.python" version="3.0.0"/>
            <import addon="script.module.requests"/>
        </requires>
        <extension point="xbmc.python.pluginsource" library="default.py">
            <provides>video</provides>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="es">Explora contenido de Atresplayer</summary>
            <description lang="es">Explora el catálogo de Atresplayer y busca vídeos en internet que coincidan. Este addon no aloja ningún contenido, solo actúa como buscador.</description>
            <platform>all</platform>
            <license>Proprietary</license>
            <assets>
                <icon>icon.png</icon>
                <fanart>fanart.png</fanart>
            </assets>
        </extension>
    </addon>
</addons>
